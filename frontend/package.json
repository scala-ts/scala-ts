{
  "name": "scala-ts-demo-frontend",
  "version": "0.0.1",
  "license": "disable-warning",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "clean-dist": "rimraf ./dist",
    "dev": "vite --host 0.0.0.0 --port ${FRONTEND_PORT:-5173}",
    "build": "yarn check-circular-dependencies && yarn clean-dist && svelte-check && tsc --noEmit && vite build",
    "serve": "sirv dist --host 0.0.0.0 --port ${FRONTEND_PORT:-5173} --single",
    "preview": "vite preview --host 0.0.0.0 --port ${FRONTEND_PORT:-5173}",
    "check-circular-dependencies": "node build/check-circular-deps.js",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "reset": "rm -rf node_modules && rm yarn.lock && yarn cache clean && yarn"
  },
  "dependencies": {
    "idonttrustlikethat": "2.1.2",
    "space-lift": "1.0.4",
    "typescript-router": "0.0.6"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/estree": "1.0.8",
    "@types/expect": "24.3.2",
    "@types/mocha": "10.0.10",
    "@types/node": "25.4.0",
    "esbuild": "0.27.3",
    "expect": "30.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "madge": "^8.0.0",
    "mocha": "11.7.5",
    "prettier": "3.8.1",
    "prettier-plugin-svelte": "3.5.1",
    "rimraf": "6.1.3",
    "sass": "1.97.3",
    "sirv-cli": "3.0.1",
    "svelte": "^5.53.9",
    "svelte-check": "^4.4.5",
    "svelte-preprocess": "6.0.3",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vite": "^7.3.1"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  }
}
